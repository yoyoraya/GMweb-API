PORT=3030
HOST=0.0.0.0
API_TOKEN=change-me
NODE_ENV=development

# false is best on Windows for first pairing. On a VPS without a display, use true.
HEADLESS=false

# Browser profile is where the Google Messages pairing/session is stored.
USER_DATA_DIR=./data/browser-profile

# Optional: use the Chrome already installed on the machine when Playwright
# cannot download Chromium.
CHROME_EXECUTABLE_PATH=

# launch: Playwright starts Chrome. connect: attach to an already-running Chrome.
BROWSER_MODE=launch
BROWSER_CDP_URL=http://127.0.0.1:9222
BROWSER_PROBE_TIMEOUT_MS=15000

# 0 disables background polling for faster send operations.
POLL_INTERVAL_MS=0
CONVERSATION_CACHE_FILE=./data/conversation-cache.json
CONVERSATION_INDEX_FILE=./data/conversation-index.json

# Conservative send pacing: at least 15s between starts and at most 4/minute.
SEND_MIN_INTERVAL_MS=15000
SEND_MAX_PER_MINUTE=4
SEND_TIMEOUT_MS=240000
# Normal messages and all delayed retries are held 02:00–08:00 Tehran time.
# Only a fresh HIGH first attempt bypasses the hold.
SEND_TIMEZONE=Asia/Tehran
SEND_QUIET_START_HOUR=2
SEND_QUIET_END_HOUR=8
# Prevent recovery loops while still healing the first confirmed automation hang.
HARD_RESTART_COOLDOWN_MS=300000
# Load sidebar history in batches until a previous-year timestamp is reached.
CONVERSATION_HISTORY_MAX_BATCHES=80
# Startup uses the persisted index and caps first-time DOM expansion.
CONVERSATION_INDEX_MAX_BATCHES=6
CONVERSATION_INDEX_BUDGET_MS=45000

# Optional webhook for new-message events.
WEBHOOK_URL=

# Keep false in production. This route exposes page text for selector debugging.
ENABLE_DEBUG_ROUTES=false

# Let load balancers check /health without auth.
PUBLIC_HEALTH=true
CORS_ORIGIN=

# Browser dashboard served by the API at /dashboard.
DASHBOARD_ENABLED=true
ADMIN_ACTIONS_ENABLED=true
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD_HASH=
DASHBOARD_PASSWORD_SESSION_TTL_MS=600000
DASHBOARD_PASSWORD_WINDOW_MS=900000
DASHBOARD_PASSWORD_MAX=5
DASHBOARD_COOKIE_SECURE=false
DASHBOARD_SESSION_TTL_MS=43200000
DASHBOARD_BIND_USER_AGENT=true
DASHBOARD_LOGIN_WINDOW_MS=60000
DASHBOARD_LOGIN_MAX=20
ADMIN_ACTION_WINDOW_MS=60000
ADMIN_ACTION_MAX=60
VNC_PROXY_TARGET=http://127.0.0.1:6080
