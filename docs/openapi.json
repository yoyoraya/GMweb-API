      }
    },
    "/events": {
      "get": {
        "summary": "Server-Sent Events stream",
        "tags": [
          "Messaging"
        ],
        "description": "Subscribe to real-time events using SSE (Server-Sent Events).\n\n**Event types:**\n- `conversation_changed` — a conversation's last message or unread state changed\n- `send_queued` — a message was accepted into the send queue\n- `send_processing` — the worker started sending a queued message\n- `send_completed` — a queued message was sent successfully (includes `jobId`)\n- `send_failed` — a send attempt failed (`willRetry` indicates if it will be retried)\n\n**Usage (JavaScript):**\n```js\nconst es = new EventSource('/events', { headers: { Authorization: 'Bearer gmw_...' } });\nes.onmessage = (e) => console.log(JSON.parse(e.data));\n```\n\nConnection stays open until closed by the client. Reconnect with exponential backoff.",
        "responses": {
          "200": {
            "description": "SSE stream",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string",
                  "description": "SSE stream"
                }
              }
            }
          }
        }
      }
    }
