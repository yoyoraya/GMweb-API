                      "type": [
                        "null",
                        "string"
                      ]
                    },
                    "createdAt": {
                      "type": [
                        "null",
                        "string"
                      ]
                    },
                    "processedAt": {
                      "type": [
                        "null",
                        "string"
                      ]
                    },
                    "finishedAt": {
                      "type": [
                        "null",
                        "string"
                      ]
                    }
